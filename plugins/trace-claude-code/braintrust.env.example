# Braintrust tracing — per-project env
# Copy to your project at one of:
#   <project>/.github/hooks/braintrust.env   (recommended for Copilot CLI)
#   <project>/.braintrust.env
# and gitignore it. Hook scripts auto-source the first match (any var
# already exported in the shell takes precedence).

TRACE_TO_BRAINTRUST=true
BRAINTRUST_API_KEY=sk-your-key-here
BRAINTRUST_CC_PROJECT=your-project-name

# Optional
# BRAINTRUST_CC_DEBUG=true
# BRAINTRUST_API_URL=https://api.braintrust.dev
